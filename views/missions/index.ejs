<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="stylesheet" href="/stylesheets/style.css" />

    <script src="https://cdn.tailwindcss.com"></script>

    <script
      src="https://cdn.jsdelivr.net/npm/@tailwindplus/elements@1"
      type="module"
    ></script>

    <title>GA Mafia</title>
  </head>

  <body>
    <div class="bg-red-950 py-12 sm:py-16">
            <header class="absolute inset-x-0 top-0 z-50">
        <nav
          aria-label="Global"
          class="flex items-center justify-between p-6 lg:px-8"
        >
          <div class="flex lg:flex-1">
            <a href="/" class="-m-1.5 p-1.5">
              <span class="sr-only">Your Missions</span>

              <img src="/image.png" alt="" class="mission-pic1 h-8 w-auto" />
            </a>

  
          </div>
        </nav>
      </header>
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl lg:mx-0">
          <h2
            class="text-4xl font-semibold tracking-tight text-pretty text-white sm:text-5xl"
          >
            Mafia Missions
          </h2>
          <p class="mt-2 text-lg/8 text-gray-300">
       Some missions will require team effort. Once a mission is completed, its status will be updated from pending to completed.
          </p>
        </div>

       <div class="mx-auto mt-10 grid max-w-7xl grid-cols-1 gap-x-8 gap-y-16 border-t border-gray-700 pt-10 sm:mt-16 sm:pt-16 sm:grid-cols-2 lg:grid-cols-3">

  <% missions.forEach(mission => { %>

    <article class="flex max-w-xl flex-col items-start justify-between">

      <div class="flex items-center gap-x-4 text-xs">
        <time class="text-gray-400">Jul 2, 2026</time>

        <% if(mission.isComplete == false) { %>
          <p class="rounded-full bg-gray-800/60 px-3 py-1.5 font-medium text-gray-300">
            Pending
          </p>
        <% } else { %>
          <p class="rounded-full bg-gray-800/60 px-3 py-1.5 font-medium text-gray-300">
            Completed
          </p>
        <% } %>

      </div>

      <div class="group relative grow">
        <h3 class="mt-3 text-lg font-semibold text-white group-hover:text-gray-300">
          <p>
            <span class="absolute inset-0"></span>
            <%= mission.name %>
          </a>
        </h3>

        <p class="mt-5 line-clamp-3 text-sm text-gray-400">
          <%= mission.description %>
        </p>
      </div>

    </article>

  <% }) %>

</div>
      </div>
      <footer class="border-t border-gray-700 py-6 text-center text-sm text-gray-400">
      Created by your favorite IA
    </footer>
    </div>
  </body>
 
</html>
