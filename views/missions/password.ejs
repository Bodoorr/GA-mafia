<!DOCTYPE html>
<html>
  <head>
    <title>Access Missions</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>

  <body class="bg-red-950 flex items-center justify-center min-h-screen">
    <div class="flex min-h-full flex-col justify-center px-6 py-12 lg:px-8">
      <div class="sm:mx-auto sm:w-full sm:max-w-sm">
        <img
          src="/image.png?color=red&shade=500"
          alt=""
          class="mx-auto h-30 w-auto"
        />
        <h2
          class="mt-10 text-center text-2xl/9 font-bold tracking-tight text-white"
        >
          Enter password to access missions
        </h2>
      </div>

<div class="mt-10 sm:mx-auto p-1 sm:w-full sm:max-w-sm ">
  <% if (error) { %>
    <div class="mb-6 rounded-lg border border-red-500/50 bg-red-500/10 px-4 py-3 text-center text-sm font-medium text-red-300">
      <%= error %>
    </div>
  <% } %>
        <form action="/missions/unlock" method="POST" class="space-y-6">
          <div>
            <div class="flex items-center justify-between">
              <label
                for="password"
                class="block text-sm/6 font-medium text-gray-100"
                >Password</label
              >
              <div class="text-sm">
                <a
                  href="https://ga-tamkeenbh.slack.com/team/U08M5DFPLBZ"
                  class="font-semibold text-red-400 hover:text-red-300"
                  >Forgot password?</a
                >
              </div>
            </div>
            <div class="mt-2">
              <input
                id="password"
                type="password"
                name="password"
                required
                class="block w-full rounded-md bg-white/5 px-3 py-1.5 text-base text-white outline-1 -outline-offset-1 outline-white/10 placeholder:text-gray-500 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-500 sm:text-sm/6"
              />
            </div>
          </div>

          <div>
            <button
              type="submit"
              class="flex w-full justify-center rounded-md bg-red-500 px-3 py-1.5 text-sm/6 font-semibold text-white hover:bg-red-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-500"
            >
              Unlock
            </button>
          </div>
        </form>

        <p class="mt-10 text-center text-sm/6 text-gray-400">
          Not a member?
          <a
            href="https://ga-tamkeenbh.slack.com/team/U08M5DFPLBZ"
            class="font-semibold text-red-400 hover:text-red-300"
            >Leave this page</a
          >
        </p>
      </div>
    </div>
  </body>
</html>
